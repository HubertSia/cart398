osc(42.21, 0.05, 5.841)
	.mult(osc(20, -0.119, 1)
		.modulate(noise(5, 10))
		.rotate(5.707))
	.posterize([3, 10, 2.406].fast(0.5)
		.smooth(0.846))
	.modulateRotate(o0, () => mouse.x * 0.009)
	.modulateScale(osc(2).modulateRotate(o0,.74))
  	.diff(src(o0).scale(.1))
	.out();



