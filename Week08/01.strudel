setcps(100/60/4)




$: note("e a f e ~f, c [b a g]/2 [e c]!2 ".add("<<12 24> <24 12 12> 38 26>"))
  .sound("supersaw ")
  .gain(0.35)
  .room(0.2)
  .color("green")
  .scope()
  .firstOf(2, x=>x.rev())

$:n("<0 2 1 3 2>*8")
  .scale("<A1 D2>/4:minor:pentatonic")
  .s("supersaw")
  .lpf(300)
  .lpenv("<4 3 2>*4")
  .firstOf(4, x=>x.rev())
  .gain(0.5)
